# Thunder Road Bar and Grill - Production Environment Configuration
# This file documents the production environment variables
# DO NOT commit actual .env with secrets to version control

# ======================
# Server Configuration
# ======================
APP_ENV=production
APP_DEBUG=false
FRONTEND_URL=https://trbgmidway.com
TRUST_PROXY=false
FORCE_HTTPS=true
SERVICE_NAME=Thunder Road Bar & Grill

# ======================
# Database Configuration
# ======================
DB_HOST=localhost
DB_USER=thunder_admin
DB_PASSWORD=<your_production_password>
DB_NAME=thunder_road
DB_PORT=3306
DB_CHARSET=utf8mb4

# ======================
# Authentication & Security
# ======================
JWT_SECRET=<generate_with_openssl_rand_base64_32>
JWT_EXPIRY=86400
PASSWORD_ALGO=bcrypt
BCRYPT_COST=10

# ======================
# File Upload Configuration
# ======================
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,video/mp4,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
UPLOAD_PUBLIC_PREFIX=/api/uploads

# ======================
# Rate Limiting
# ======================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL=300
RATE_LIMIT_STRICT=20
RATE_LIMIT_LOGIN=50

# ======================
# Caching
# ======================
CACHE_MENU=true
CACHE_MENU_TTL=300

# ======================
# Logging
# ======================
LOG_LEVEL=info
LOG_FILE=logs/app.log
LOG_QUERIES=false

# ======================
# Email Configuration
# ======================
SEND_EMAILS=false
SENDGRID_API_KEY=<your_sendgrid_api_key>
OPERATIONS_EMAIL=thundergrillmidway@gmail.com
SUPPORT_EMAIL=support@jamarq.digital
MAIL_FROM=no-reply@trbgmidway.com
ALERT_FROM=alerts@trbgmidway.com
ALERT_TO=support@jamarq.digital
ALERT_THROTTLE_MINUTES=15
EMAIL_PREVIEW_LOG=false
# Legacy fallback keys (honored for backwards compatibility)
STAFF_EMAIL_TO=thundergrillmidway@gmail.com
ALERTS_EMAIL_TO=support@jamarq.digital
EMAIL_FROM_NOTIFICATIONS=notifications@trbgmidway.com
EMAIL_FROM_ALERTS=alerts@trbgmidway.com
NOTIFICATION_EMAIL=thundergrillmidway@gmail.com
EMAIL_FROM=marshall.jason319@gmail.com

# ======================
# Development Options
# ======================
ALLOW_DEV_ADMIN_HEADER=false
ALLOW_PROD_TEST_EMAIL=false
REHYDRATE_TOKEN=
