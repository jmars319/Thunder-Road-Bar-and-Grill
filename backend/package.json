{
  "name": "thunder-road-backend",
  "version": "1.0.0",
  "description": "Thunder Road Bar and Grill - Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test:integration": "node tests/menu.integration.test.js",
    "lint": "eslint \"**/*.js\"",
    "lint:fix": "eslint \"**/*.js\" --fix",
    "migrate:latest": "npx knex migrate:latest --knexfile knexfile.js",
    "migrate:rollback": "npx knex migrate:rollback --knexfile knexfile.js",
    "migrate:make": "npx knex migrate:make"
  },
  "keywords": [
    "restaurant",
    "api",
    "express",
    "mysql"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^5.1.0",
  "express-rate-limit": "^7.0.0",
  "helmet": "^7.0.0",
    "express-validator": "^7.3.0",
    "knex": "^3.1.0",
    "multer": "^2.0.2",
    "mysql2": "^3.6.0",
    "file-type": "^18.0.0"
  },
  "devDependencies": {
    "eslint": "^9.37.0",
    "nodemon": "^3.0.1"
  }
}
