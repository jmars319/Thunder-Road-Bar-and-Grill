# Thunder Road Bar and Grill - PHP Backend Environment Configuration
# Copy this file to .env and update with your actual values

# ======================
# Server Configuration
# ======================

# Environment (development, production, staging)
APP_ENV=development

# Debug mode (true/false) - NEVER set to true in production
APP_DEBUG=true

# Timezone (default: America/New_York for Eastern Time)
TZ=America/New_York

# Frontend URL(s) for CORS - comma-separated for multiple origins
# Example: https://yoursite.com,https://www.yoursite.com
FRONTEND_URL=http://localhost:3000

# Trust proxy headers (true/false - required when behind reverse proxy)
TRUST_PROXY=false

# Force HTTPS redirects (true/false - set to true in production)
FORCE_HTTPS=false

# ======================
# Database Configuration
# ======================

# Database host
DB_HOST=localhost

# Database user
DB_USER=root

# Database password (REQUIRED in production)
DB_PASSWORD=

# Database name
DB_NAME=thunder_road

# Database port (optional, defaults to MySQL default 3306)
DB_PORT=3306

# Database charset
DB_CHARSET=utf8mb4

# ======================
# Authentication & Security
# ======================

# JWT secret key - MUST be changed in production!
# Generate a strong random string: openssl rand -base64 32
JWT_SECRET=dev-secret-change-in-production

# JWT token expiration time (in seconds)
# Examples: 3600 (1h), 86400 (24h), 604800 (7d)
JWT_EXPIRY=86400

# Password hashing algorithm (bcrypt recommended)
# Options: bcrypt, argon2i, argon2id
PASSWORD_ALGO=bcrypt

# Bcrypt cost factor (10-12 recommended, higher = more secure but slower)
BCRYPT_COST=10

# ======================
# File Upload Configuration
# ======================

# Upload directory (relative to backend/)
UPLOAD_DIR=uploads

# Image pipeline (MMH spec)
# 15MB default; increase if admins upload very large hero assets
IMAGE_UPLOAD_MAX_BYTES=15728640
IMAGE_JPEG_QUALITY=85
IMAGE_WEBP_QUALITY=85
IMAGE_PNG_COMPRESSION=6
RESPONSIVE_IMAGE_WIDTH_PROFILES={}

# ======================
# Rate Limiting
# ======================

# Enable rate limiting (true/false)
RATE_LIMIT_ENABLED=true

# Global rate limit (requests per minute)
RATE_LIMIT_GLOBAL=300

# Strict rate limit for write operations (requests per minute)
RATE_LIMIT_STRICT=20

# Login rate limit (attempts per 15 minutes)
RATE_LIMIT_LOGIN=5

# ======================
# Caching
# ======================

# Enable menu cache (true/false)
CACHE_MENU=true

# Menu cache TTL (in seconds)
CACHE_MENU_TTL=300

# ======================
# Logging
# ======================

# Log level (debug, info, warning, error)
LOG_LEVEL=info

# Log file location (relative to backend/)
LOG_FILE=logs/app.log

# Enable query logging (true/false - useful for debugging)
LOG_QUERIES=false

# ======================
# Email Configuration (Optional)
# ======================

# SMTP host
# SMTP_HOST=smtp.example.com

# SMTP port
# SMTP_PORT=587

# SMTP username
# SMTP_USER=

# SMTP password
# SMTP_PASSWORD=

# Email from address
# EMAIL_FROM=noreply@trbgmidway.com

# Email from name
# EMAIL_FROM_NAME=Thunder Road Bar & Grill

# ======================
# Development Options
# ======================

# Allow dev admin header authentication (true/false)
# NEVER set to true in production!
ALLOW_DEV_ADMIN_HEADER=false

# ======================
# Production Checklist
# ======================
# Before deploying to production, ensure:
# ✓ APP_ENV=production
# ✓ APP_DEBUG=false
# ✓ JWT_SECRET changed to strong random value
# ✓ DB_PASSWORD set to secure database password
# ✓ FRONTEND_URL set to your actual domain(s)
# ✓ TRUST_PROXY=true if behind reverse proxy
# ✓ FORCE_HTTPS=true to enforce HTTPS
# ✓ Default admin credentials changed in database
# ✓ ALLOW_DEV_ADMIN_HEADER=false or not set
# ✓ File permissions: 644 for .env, 755 for directories, 644 for PHP files
