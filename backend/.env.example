# Thunder Road Bar and Grill - Backend Environment Configuration
# Copy this file to .env and update with your actual values

# ======================
# Server Configuration
# ======================

# Server port (default: 5001)
PORT=5001

# Node environment (development, production, test)
NODE_ENV=development

# Frontend URL(s) for CORS - comma-separated for multiple origins
# Example: https://yoursite.com,https://www.yoursite.com
FRONTEND_URL=http://localhost:3000

# Trust proxy headers (required when behind reverse proxy like nginx)
# Set to 'true' or '1' in production behind proxy
TRUST_PROXY=false

# Force HTTPS redirects (set to 'true' in production)
FORCE_HTTPS=false

# ======================
# Database Configuration
# ======================

# --- Render / PostgreSQL (Production) ---
# Use DATABASE_URL for Render PostgreSQL deployment
# Format: postgresql://user:password@host:5432/database
# This is automatically provided by Render when you link a PostgreSQL database
# DATABASE_URL=postgresql://user:password@host:5432/thunder_road

# --- MySQL (Local Development) ---
# For local development with MySQL, use these individual variables:

# Database host
DB_HOST=localhost

# Database user
DB_USER=root

# Database password (REQUIRED in production)
DB_PASSWORD=

# Database name
DB_NAME=thunder_road

# Database port (optional, defaults to MySQL default 3306, PostgreSQL uses 5432)
# DB_PORT=3306

# Connection pool limit (default: 10)
DB_CONN_LIMIT=10

# ======================
# Authentication & Security
# ======================

# JWT secret key - MUST be changed in production!
# Generate a strong random string: openssl rand -base64 32
JWT_SECRET=dev-secret-change-in-production

# JWT token expiration time (default: 24h)
# Examples: 1h, 24h, 7d
JWT_EXPIRY=24h

# ======================
# Development Options
# ======================

# Allow dev admin header authentication (NEVER set to 1 in production!)
# Only works when NODE_ENV !== 'production'
ALLOW_DEV_ADMIN_HEADER=0

# Log level (debug, info, warn, error)
# Default: debug in development, info in production
# LOG_LEVEL=info

# ======================
# Optional Script Variables
# ======================

# Base API URL for integration tests
# API_BASE=http://localhost:5001/api

# Social media URLs for setup scripts
# FACEBOOK_URL=https://facebook.com/yourpage
# GOOGLE_URL=https://maps.google.com/yourplace

# ======================
# Production Checklist
# ======================
# Before deploying to production, ensure:
# ✓ NODE_ENV=production
# ✓ JWT_SECRET changed to strong random value
# ✓ DB_PASSWORD set to secure database password
# ✓ FRONTEND_URL set to your actual domain(s)
# ✓ TRUST_PROXY=true if behind reverse proxy
# ✓ FORCE_HTTPS=true to enforce HTTPS
# ✓ Default admin credentials changed in database
# ✓ ALLOW_DEV_ADMIN_HEADER not set or set to 0
