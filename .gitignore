# Root .gitignore for Thunder Road project

# ───────────────────────────
# Local documentation / helpers
# ───────────────────────────
copilot-instructions/
styling-instructions/
.archive/

# ───────────────────────────
# Environment & secrets
# ───────────────────────────
.env
.env.*
!.env.example
!.env.production.example
frontend/.env.production

# ───────────────────────────
# Dev script state
# ───────────────────────────
.dev/
!.dev/.gitignore

# ───────────────────────────
# Deploy artifacts
# ───────────────────────────
deploy-*.zip
frontend-deploy*.zip
backend-deploy*.zip
server-config*.zip

# ───────────────────────────
# Runtime uploads / incoming
# ───────────────────────────
backend/uploads/**
!backend/uploads/.gitignore
!backend/uploads/**/.gitignore
!backend/uploads/**/.gitkeep
!backend/uploads/.htaccess
backend/incoming/**
!backend/incoming/.gitignore
!backend/incoming/.gitkeep

# ───────────────────────────
# Node / frontend
# ───────────────────────────
node_modules/
frontend/node_modules/
/build
frontend/build/
frontend/.stylelintrc.json

# ───────────────────────────
# Logs & coverage
# ───────────────────────────
*.log
*.pid
npm-debug.log*
yarn-debug.log*
yarn-error.log*
backend.log
backend/*.log
backend-start.log
test-logs/
coverage/

# ───────────────────────────
# OS / editor files
# ───────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ───────────────────────────
# Misc temp files
# ───────────────────────────
*.NEW
*.backup

# ───────────────────────────
# Public asset temp folders
# ───────────────────────────
/frontend/public/favicon-backup*

# ───────────────────────────
# Backend runtime cache (must not be committed)
# ───────────────────────────
backend/cache/
!backend/cache/.gitignore

# ───────────────────────────
# PHP / hosting noise
# ───────────────────────────
*.phar
*.cache
