# Root .gitignore for Thunder Road project

# Ignore copilot and styling instruction docs (keep them local/private)
copilot-instructions/
styling-instructions/

# Node
node_modules/

# Build outputs
/build

# OS
.DS_Store

# Environment
.env
.env.local
.env.*.local

# Local frontend production env (contains production API urls and secrets)
frontend/.env.production

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor
.vscode/

# Ignore backend uploads (backend/.gitignore already allows uploads/.gitkeep)
backend/uploads/

# Local stylelint config - keep it untracked
frontend/.stylelintrc.json

# Ignore temporary editor copies
*.NEW

# ignore backup files
*.backup

# Archive folder for old documentation (local only)
.archive/

# Ignore favicon backup folders created during asset updates
/frontend/public/favicon-backup*

# Runtime logs
*.log
*.pid
backend.log
backend/*.log
backend-start.log
test-logs/
