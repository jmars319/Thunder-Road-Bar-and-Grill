{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "lucide-react": "^0.545.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^13.5.0",
    "playwright": "^1.57.0",
    "react-scripts": "5.0.1",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^36.0.1",
    "stylelint-order": "^6.0.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "GENERATE_SOURCEMAP=false react-scripts build",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint \"src/**/*.{js,jsx}\"",
    "lint:css": "stylelint \"src/**/*.css\" --allow-empty-input",
    "lint:fix": "eslint \"src/**/*.{js,jsx}\" --fix",
    "check:public-assets": "node ./scripts/check_public_assets.js",
    "cls:headless": "node ./scripts/cls_headless.js",
    "test:ci": "react-scripts test --watchAll=false --runInBand",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "overrides": [
      {
        "files": [
          "src/**/*.{test,spec}.{js,jsx}",
          "src/**/__tests__/**/*.{js,jsx}"
        ],
        "rules": {
          "testing-library/no-node-access": "off",
          "testing-library/no-container": "off",
          "testing-library/prefer-screen-queries": "off"
        }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "packageManager": "npm@11.6.1",
  "engines": {
    "node": ">=22.12.0 <23"
  }
}
